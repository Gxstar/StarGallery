<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Media Container - Ensures everything fills the screen -->
    <FrameLayout
        android:id="@+id/mediaContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Image Viewer - Main display for photos -->
        <com.gxstar.stargallery.ui.detail.EdgeSubsamplingScaleImageView
            android:id="@+id/ivPhoto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- GIF Viewer -->
        <ImageView
            android:id="@+id/ivGif"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <!-- Video Cover -->
        <ImageView
            android:id="@+id/ivVideoCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:visibility="gone" />
        
        <!-- Large Play Button -->
        <ImageView
            android:id="@+id/ivPlayButton"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play_circle"
            android:visibility="gone"
            android:background="@drawable/bg_play_button"
            android:elevation="4dp" />

        <!-- Video Player View -->
        <androidx.media3.ui.PlayerView
            android:id="@+id/videoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:show_buffering="never"
            app:use_controller="true"
            app:resize_mode="fit"
            app:surface_type="surface_view"
            app:controller_layout_id="@layout/exo_player_controller_view"
            app:auto_show="false" />

    </FrameLayout>

    <!-- RAW Status Tag (positioned below the potential status bar area) -->
    <TextView
        android:id="@+id/tvRawTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_raw_tag"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:text="RAW"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:visibility="gone"
        android:elevation="2dp" />

    <!-- Loading Spinner -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="visible" />

</FrameLayout>
