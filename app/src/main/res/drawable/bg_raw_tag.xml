<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 渐变背景 - 深灰色到稍浅的灰色 -->
    <gradient
        android:startColor="#E6000000"
        android:endColor="#CC1A1A1A"
        android:angle="135" />
    
    <!-- 圆角 -->
    <corners android:radius="4dp" />
    
    <!-- 内边距 -->
    <padding
        android:left="8dp"
        android:right="8dp"
        android:top="3dp"
        android:bottom="3dp" />
</shape>
