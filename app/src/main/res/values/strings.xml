    <string name="privacy_policy_intro">感谢您使用相册。我们非常重视您的隐私和个人信息保护。</string>

    <!-- 权限说明 -->
    <string name="permissions_title">权限说明</string>
    <string name="permissions_subtitle">应用请求的权限及其用途</string>
    <string name="permissions_intro">相册应用请求以下权限以提供核心功能。所有权限仅用于访问本地媒体文件，不会用于任何其他目的。</string>
    <string name="permission_media_images_title">读取媒体图片 (READ_MEDIA_IMAGES)</string>
    <string name="permission_media_images_desc">用于访问设备上的照片，是应用的核心功能。此权限仅允许读取照片，不会修改或删除任何文件。</string>
    <string name="permission_media_video_title">读取媒体视频 (READ_MEDIA_VIDEO)</string>
    <string name="permission_media_video_desc">用于访问设备上的视频文件，以便在相册中展示和播放视频内容。</string>
    <string name="permission_storage_title">读取存储 (READ_EXTERNAL_STORAGE)</string>
    <string name="permission_storage_desc">用于兼容 Android 11 (API 30) 以下版本的设备。在 Android 11 及以上版本中，应用使用 scoped storage 保护您的隐私。</string>
    <string name="permission_user_selected_title">用户选择的媒体 (READ_MEDIA_VISUAL_USER_SELECTED)</string>
    <string name="permission_user_selected_desc">用于在 Android 14+ 设备上访问用户特别选择的照片，即使应用尚未获得完整媒体���权限。</string>
    <string name="permissions_note">您可以在系统设置中的应用权限管理中随时撤销这些权限。撤销权限后，应用将无法访问相应的媒体文件。</string>

